# TMDB credentials — used ONLY by scripts/build-data.ts at build time.
# These never end up in the browser bundle.
# Get a free key at https://www.themoviedb.org/settings/api

# v3 API key:
TMDB_API_KEY=

# ...or a v4 read access token (Bearer). Either one works.
TMDB_READ_TOKEN=

# --- Cloud sync (optional) --------------------------------------------------
# Supabase project URL + anon key. These are PUBLIC values (safe to expose in
# the browser and to commit); the database is protected by Row Level Security.
# Leave empty to run local-only (no accounts, localStorage + export/import).
# Create a project at https://supabase.com and run supabase/schema.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
